NODE_ENV=development
PORT=5001
# Atlas: put DATABASE name before ? — e.g. ...mongodb.net/niat_insider?retryWrites=true&w=majority
# Passwords with special chars (@ # : / ? &) must be percent-encoded in the URI (e.g. p@ss → p%40ss)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/niat_insider?retryWrites=true&w=majority

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=1d
# Comma-separated origins (no trailing slash). Localhost/127.0.0.1 any port is allowed by server code for dev.
CORS_ORIGIN=http://localhost:5176

# --- Render.com (Dashboard → Environment only; do not commit secrets) ---
# NODE_ENV=production
# PORT is injected by Render
# MONGODB_URI=mongodb+srv://...mongodb.net/niat_insider?retryWrites=true&w=majority
# JWT_SECRET=long random string (32+ chars)
# JWT_EXPIRES_IN=1d
# CORS_ORIGIN=https://your-app.vercel.app,https://www.yourdomain.com
