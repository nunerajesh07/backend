NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=1d
# Comma-separated deployed/staging origins. Loopback (localhost / 127.0.0.1, any port) is always allowed for local tools.
CORS_ORIGIN=http://localhost:5174

# --- Render.com (set in Dashboard → Environment, not committed) ---
# NODE_ENV=production
# PORT is injected by Render — do not set manually unless you know why
# MONGODB_URI=your Atlas URI
# JWT_SECRET=long random string
# JWT_EXPIRES_IN=1d
# CORS_ORIGIN=https://your-frontend.onrender.com,https://your-custom-domain.com
